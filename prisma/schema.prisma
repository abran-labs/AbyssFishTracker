generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries      FishEntry[]
  pondSnapshot PondSnapshot?
}

model FishEntry {
  id           String   @id @default(cuid())
  fishName     String
  weight       Float
  stars        Int
  mutation     String
  value        Float
  optimization Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PondSnapshot {
  id        String   @id @default(cuid())
  fishIds   String[] // ordered list of fish IDs in the acknowledged pond
  pondSize  Int      @default(6)
  createdAt DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}
