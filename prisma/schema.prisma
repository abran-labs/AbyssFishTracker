generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries      FishEntry[]
  pondSnapshot PondSnapshot?
  settings     UserSettings?
}

model UserSettings {
  id              String  @id @default(cuid())
  race            String  @default("None")
  artifact1       String  @default("None")
  artifact2       String  @default("None")
  artifact3       String  @default("None")
  roeStorageLevel Int     @default(0)
  decorationLevel Int     @default(0)
  pondSortNoticeDismissed Boolean   @default(false)
  ignoredSwapFishIds      String[]  @default([])
  pondIsOffline           Boolean   @default(true)
  pondFeedType            String    @default("None")
  pondFeedBags            Int       @default(1)
  pondReminderFeedAt      DateTime?
  pondReminderStorageAt   DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FishEntry {
  id           String   @id @default(cuid())
  fishName     String
  weight       Float
  stars        Int
  mutation     String
  value        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PondSnapshot {
  id        String   @id @default(cuid())
  fishIds   String[] // ordered list of fish IDs in the acknowledged pond
  pondSize  Int      @default(6)
  createdAt DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model GlobalStat {
  id        String   @id @default(cuid())
  name      String   @unique
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

