generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  banned      Boolean  @default(false)
  lastKnownIp String?

  entries      FishEntry[]
  pondSnapshot PondSnapshot?
  settings     UserSettings?
}

model BannedIp {
  id        String   @id @default(cuid())
  ip        String   @unique
  createdAt DateTime @default(now())
}

model UserSettings {
  id              String  @id @default(cuid())
  race            String  @default("None")
  artifact1       String  @default("None")
  artifact2       String  @default("None")
  artifact3       String  @default("None")
  roeStorageLevel Int     @default(0)
  decorationLevel Int     @default(0)
  pondSortNoticeDismissed Boolean   @default(false)
  ignoredSwapFishIds      String[]  @default([])
  pondIsOffline           Boolean   @default(true)
  pondFeedType            String    @default("None")
  pondFeedBags            Int       @default(1)
  pondReminderFeedAt      DateTime?
  pondReminderStorageAt   DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FishEntry {
  id           String   @id @default(cuid())
  fishName     String
  weight       Float
  stars        Int
  mutation     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PondSnapshot {
  id        String   @id @default(cuid())
  fishIds   String[] // ordered list of fish IDs in the acknowledged pond
  pondSize  Int      @default(6)
  createdAt DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model GlobalStat {
  id        String   @id @default(cuid())
  name      String   @unique
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model FeedbackPost {
  id          String   @id @default(cuid())
  type        String   // "suggestion" or "issue"
  title       String
  description String
  status      String   @default("open") // open, liked, in_progress, planned, completed, laughing
  upvotes     Int      @default(1) // starts at 1 (auto-upvoted by creator)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String?
  authorEmail String?
  pinned      Boolean  @default(false)
  locked      Boolean  @default(false)

  comments    FeedbackComment[]
  votes       FeedbackUpvote[]

  @@index([type])
}

model FeedbackComment {
  id          String   @id @default(cuid())
  content     String
  createdAt   DateTime @default(now())
  authorId           String?
  authorEmail        String?
  parentId           String?
  deleted            Boolean  @default(false)
  deletedByModerator Boolean  @default(false)

  postId  String
  post    FeedbackPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  FeedbackComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies FeedbackComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([parentId])
}

model FeedbackUpvote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   FeedbackPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String

  @@unique([postId, userId])
}

