# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/abyssfishlog?schema=public"

# Secret key for signing JWT session tokens (generate a random 64+ char string)
JWT_SECRET="change-me-to-a-random-secret"

# Resend API key for sending OTP emails (https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# Email address that OTP emails are sent from (must be verified in Resend)
EMAIL_FROM="noreply@yourdomain.com"
